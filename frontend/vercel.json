{
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth" },
    { "source": "/api/doctors/:path*", "destination": "/api/doctors" },
    { "source": "/api/doctors", "destination": "/api/doctors" },
    { "source": "/api/appointments/:path*", "destination": "/api/appointments" },
    { "source": "/api/appointments", "destination": "/api/appointments" },
    { "source": "/api/patient/dashboard", "destination": "/api/appointments" },
    { "source": "/api/doctor/dashboard", "destination": "/api/doctors" },
    { "source": "/api/doctor/clinics/:path*", "destination": "/api/doctors" },
    { "source": "/api/payments/:path*", "destination": "/api/payments" },
    { "source": "/api/payments", "destination": "/api/payments" },
    { "source": "/api/assistant/payments", "destination": "/api/payments" },
    { "source": "/api/assistant/verify-payment", "destination": "/api/payments" },
    { "source": "/api/prescriptions/:path*", "destination": "/api/prescriptions" },
    { "source": "/api/prescriptions", "destination": "/api/prescriptions" },
    { "source": "/api/patients/:path*", "destination": "/api/appointments" },
    { "source": "/api/admin/:path*", "destination": "/api/admin" }
  ]
